    "@aws-sdk/lib-dynamodb": "^3.817.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/aws-lambda": "^8.10.146",
    "@types/node": "^22.15.23",
    "@vitest/coverage-v8": "^3.1.1",
    "esbuild": "^0.25.12",
    "typescript": "~5.7.2",
    "vitest": "^3.1.1"
  }
}
