{
  "name": "@vln-devsecops/contact-form-lambda",
  "license": "MIT",
  "version": "1.0.0",
  "type": "module",
  "description": "Lambda handler source for the contact_form module (submit, admin).",
  "files": [
    "dist/"
  ],
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "public"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
